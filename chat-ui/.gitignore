# =========================
# 🔹 GLOBAL IGNORE
# =========================

# Node modules (ALL services)
node_modules/
**/node_modules/

# Environment files
.env
.env.*
**/.env
**/.env.*

# Build outputs
dist/
build/
.next/
out/
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# =========================
# 🔹 NEXT.JS (chat-ui)
# =========================

chat-ui/.next/
chat-ui/out/

# =========================
# 🔹 BACKEND + AGENT (Express)
# =========================

backend-service/dist/
agent-service/dist/

# Optional temp files
tmp/
temp/

# =========================
# 🔹 PACKAGE MANAGERS
# =========================

.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# 🔹 VERCEL / DEPLOY
# =========================

.vercel

# =========================
# 🔹 MISC
# =========================

*.pem